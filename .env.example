# Sanity — finmagix.com blog
# projectId is PUBLIC (documented in the session brief) — safe to commit.
NEXT_PUBLIC_SANITY_PROJECT_ID="i7v8b5ym"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-12-01"

# Optional. Only needed if the dataset is private or to read drafts.
# A read (viewer) token — never a write token. Set in Vercel, not here.
SANITY_API_READ_TOKEN=""

# Publish webhook -> revalidation. Must match the secret configured on the
# Sanity webhook (Manage -> API -> Webhooks). Required for publish -> live.
SANITY_REVALIDATE_SECRET=""
